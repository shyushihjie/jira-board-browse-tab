{
  "manifest_version": 3,
  "name": "Jira Board Browse Tab",
  "version": "0.1.0",
  "description": "Open Jira board cards in a dedicated /browse issue tab instead of the board sidebar.",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "optional_host_permissions": [
    "https://*.atlassian.net/*",
    "https://*.atlassian.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Jira Board Browse Tab",
    "default_popup": "src/popup.html"
  },
  "options_page": "src/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
